NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Credenciales demo visibles en /login (solo si están seteadas).
# No usar en producción real.
NEXT_PUBLIC_DEMO_EMAIL=
NEXT_PUBLIC_DEMO_PASSWORD=

# Resend para email automático de invitaciones (opcional).
# Si no está, /api/invitations devuelve el link para copiar a mano.
# Free tier: 3000 emails/mes. https://resend.com/api-keys
RESEND_API_KEY=
# Remitente. Para testing: "Odonto Gestión <onboarding@resend.dev>".
# En producción usar dominio validado: "Odonto Gestión <invitaciones@tudominio.com>".
RESEND_FROM_EMAIL=
